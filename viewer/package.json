{
  "name": "papyri-viewer",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Read-only web viewer for papyri IR bundles. See PLAN.md.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:cf": "PAPYRI_ADAPTER=cloudflare astro build",
    "preview": "astro preview",
    "serve": "node ./dist/server/entry.mjs",
    "wrangler": "wrangler",
    "wrangler:dev": "wrangler dev --config dist/server/wrangler.json --persist-to .wrangler/state",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint src --ext .ts,.tsx,.astro",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.0",
    "astro": "^6.1.10",
    "better-sqlite3": "^12.9.0",
    "cbor-x": "^1.6.4",
    "katex": "^0.16.45",
    "papyri-ingest": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.2.1",
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro-eslint-parser": "^1.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.2.3",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.17.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": ">=22"
  }
}
